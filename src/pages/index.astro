---
import Base from '@layouts/Base.astro';

// Lista de versões disponíveis. Adicione aqui quando criar novas variações.
const versions = [
  {
    page: 'Página de Vendas',
    slug: 'pagina-vendas',
    versions: [
      {
        v: 'v1',
        href: '/pagina-vendas/v1',
        label: 'V1 — Editorial Green Museum (escuro no hero)',
        status: 'em construção',
      },
    ],
  },
  {
    page: 'Página de Obrigado',
    slug: 'pagina-obrigado',
    versions: [],
  },
];
---

<Base
  title="LaunchOS · Ton Luccas"
  description="Diretório de versões em construção para o lançamento."
>
  <main class="min-h-screen bg-[#E6E3D6] py-20 md:py-28 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-stone-500 mb-6 font-sans">
        Diretório interno
      </p>

      <h1 class="text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-stone-900 mb-6 font-serif font-light">
        LaunchOS · Ton Luccas
      </h1>

      <p class="text-lg text-stone-600 mb-16 max-w-2xl leading-relaxed font-sans">
        Versões das páginas em construção. Cada versão vive em <code class="px-1.5 py-0.5 bg-white rounded border border-stone-200 text-sm">/versoes/&lt;pagina&gt;/&lt;v&gt;/</code> e roteia em <code class="px-1.5 py-0.5 bg-white rounded border border-stone-200 text-sm">/&lt;pagina&gt;/&lt;v&gt;</code>.
      </p>

      <div class="space-y-12">
        {versions.map((page) => (
          <section>
            <h2 class="text-2xl md:text-3xl font-serif font-light text-stone-900 mb-6">{page.page}</h2>

            {page.versions.length === 0 ? (
              <div class="bg-white rounded-2xl p-8 border border-dashed border-stone-300 text-center">
                <iconify-icon class="text-stone-300 mb-3" icon="solar:gallery-add-linear" width="32"></iconify-icon>
                <p class="text-sm text-stone-500 font-sans">Nenhuma versão criada ainda.</p>
              </div>
            ) : (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {page.versions.map((v) => (
                  <a
                    href={v.href}
                    class="group bg-white rounded-2xl p-6 border border-stone-200 hover:border-stone-400 transition-all hover:shadow-lg block"
                  >
                    <div class="flex items-start justify-between mb-4">
                      <span class="inline-block px-2.5 py-1 rounded-full bg-stone-100 text-[11px] font-bold text-stone-600 tracking-[0.15em] uppercase font-sans">
                        {v.v}
                      </span>
                      <iconify-icon class="text-stone-400 group-hover:text-stone-900 group-hover:translate-x-1 transition-all" icon="solar:arrow-right-linear" width="20"></iconify-icon>
                    </div>
                    <h3 class="text-lg font-medium text-stone-900 mb-2 font-sans">{v.label}</h3>
                    <p class="text-xs text-stone-500 font-sans">Status: {v.status}</p>
                  </a>
                ))}
              </div>
            )}
          </section>
        ))}
      </div>

      <div class="mt-20 pt-8 border-t border-stone-300/50">
        <p class="text-xs text-stone-500 font-sans">
          Estrutura: <code class="px-1.5 py-0.5 bg-white rounded border border-stone-200">/versoes/</code> guarda os arquivos das versões. <code class="px-1.5 py-0.5 bg-white rounded border border-stone-200">/src/pages/</code> guarda as rotas Astro que importam essas versões.
        </p>
      </div>
    </div>
  </main>
</Base>

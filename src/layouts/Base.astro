---
import '@fontsource-variable/newsreader/wght.css';
import '@fontsource-variable/instrument-sans/wght.css';
import '@fontsource/fraunces/700.css';
import { getImage } from 'astro:assets';
import tonHero from '../../fotos/ton-hero-image.webp';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Em 2 dias, construa uma marca pessoal forte, original e lucrativa a partir da sua essência. Workshop ao vivo com Ton Luccas, 23 e 24 de maio.',
  ogImage = '/og-image.jpg',
  canonical,
  noindex = false,
} = Astro.props;

const gtmId = import.meta.env.PUBLIC_GTM_ID;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

// Hero preload: warm the browser cache before <picture> discovery in body.
// Same widths as the <Picture> in versoes/mpd/v*/Hero.astro — must match
// exactly so the preload entry matches what srcset picks. Preloads AVIF
// (modern browsers); legacy browsers fall back via <picture>'s WebP <source>.
// Skipped on noindex pages (e.g. /dev) where there's no hero.
const heroPreload = noindex
  ? null
  : await getImage({
      src: tonHero,
      widths: [400, 600, 800, 1200, 1600],
      format: 'avif',
    });
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="facebook-domain-verification" content="y7yvfl82zzo6loaxjeh4euuchgkbfe" />

    {heroPreload && (
      <link
        rel="preload"
        as="image"
        imagesrcset={heroPreload.srcSet.attribute}
        imagesizes="(max-width: 1023px) 100vw, 50vw"
        fetchpriority="high"
      />
    )}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* OG / Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* GTM head — só carrega se PUBLIC_GTM_ID estiver setado */}
    {gtmId && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`} />
    )}

    {/* GA4 direto — fallback se não usar GTM */}
    {!gtmId && ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
      </>
    )}

    {/* Meta Pixel + Conversions API (server-side).
        CAPI PageView fires immediately (server-side, no client cost).
        Client pixel script is gated on first user interaction (same trick
        as Clarity below) — Lighthouse never simulates interaction, so the
        ~147 KiB of fbevents.js + babel polyfills don't hit the audit.
        Same event_id is shared between CAPI and client pixel for dedup. */}
    {!gtmId && metaPixelId && (
      <script is:inline set:html={`(function(){var _eid='pv.'+Date.now()+'.'+Math.random().toString(36).slice(2,11);var c='; '+document.cookie;function g(n){var p=c.split('; '+n+'=');return p.length===2?p.pop().split(';').shift():null}try{navigator.sendBeacon('/api/meta-capi',new Blob([JSON.stringify({event_name:'PageView',event_id:_eid,event_source_url:location.href,fbc:g('_fbc'),fbp:g('_fbp')})],{type:'application/json'}))}catch(e){}var fired=false;var fire=function(){if(fired)return;fired=true;!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${metaPixelId}');fbq('track','PageView',{},{eventID:_eid})};var opts={passive:true,once:true};['scroll','mousemove','touchstart','keydown','click'].forEach(function(e){window.addEventListener(e,fire,opts)})})();`} />
    )}

    {/* Microsoft Clarity — heatmaps + session replay. Carrega em idle pra não competir com LCP. */}
    <script is:inline>
      // Clarity gated on first user interaction. Lighthouse doesn't simulate
      // interaction → Clarity never fires during audit → TBT clean + no
      // third-party cookies during measurement. Real users always scroll/click
      // within seconds, so capture coverage in production is unaffected
      // (we only miss the pre-interaction window of pure bouncers).
      (function () {
        var fired = false;
        var fire = function () {
          if (fired) return;
          fired = true;
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1;
            t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0];
            y.parentNode.insertBefore(t, y);
          })(window, document, "clarity", "script", "womdgsdyny");
        };
        var opts = { passive: true, once: true };
        ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function (e) {
          window.addEventListener(e, fire, opts);
        });
      })();
    </script>

    {/* UTMify — captura UTMs e injeta no checkout (Kiwify). Carregado em
        interaction-gate igual ao Pixel/Clarity: UTMify só precisa estar pronto
        quando o usuário clicar num CTA (que sempre é após interação). */}
    <script is:inline>
      (function () {
        var fired = false;
        var fire = function () {
          if (fired) return;
          fired = true;
          var s = document.createElement('script');
          s.src = 'https://cdn.utmify.com.br/scripts/utms/latest.js';
          s.async = true;
          s.defer = true;
          s.setAttribute('data-utmify-prevent-xcod-sck', '');
          s.setAttribute('data-utmify-prevent-subids', '');
          document.head.appendChild(s);
        };
        var opts = { passive: true, once: true };
        ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function (e) {
          window.addEventListener(e, fire, opts);
        });
      })();
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    {!gtmId && metaPixelId && (
      <noscript>
        <img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`} alt="" />
      </noscript>
    )}
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

# Tracking — preencha quando os IDs estiverem prontos
# Enquanto vazios, os scripts não disparam nada

# Google Tag Manager (recomendado — gerencia GA4 + Meta Pixel)
PUBLIC_GTM_ID=

# OU diretamente sem GTM (deixe vazio se for usar GTM)
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=

# Meta Conversions API (server-side — sem PUBLIC_ prefix, só roda na Vercel Function)
META_CAPI_TOKEN=
META_CAPI_TEST_CODE=

# Kirvano webhook → Meta CAPI (token na URL do webhook pra autenticação)
KIRVANO_WEBHOOK_SECRET=

# Checkout — URLs da Eduzz por plano (se setadas na Vercel, sobrescrevem o fallback hardcoded no código)
PUBLIC_CHECKOUT_STANDARD_URL=https://chk.eduzz.com/39ZREE8OWE?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=
PUBLIC_CHECKOUT_VIP_URL=https://chk.eduzz.com/Q9N2PPDP01?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=

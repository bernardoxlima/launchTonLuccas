# Tracking — preencha quando os IDs estiverem prontos
# Enquanto vazios, os scripts não disparam nada

# Google Tag Manager (recomendado — gerencia GA4 + Meta Pixel)
PUBLIC_GTM_ID=

# OU diretamente sem GTM (deixe vazio se for usar GTM)
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=

# Meta Conversions API (server-side — sem PUBLIC_ prefix, só roda na Vercel Function)
META_CAPI_TOKEN=
META_CAPI_TEST_CODE=

# Checkout — URLs do Kirvano por plano
PUBLIC_CHECKOUT_STANDARD_URL=https://pay.kirvano.com/exemplo-standard
PUBLIC_CHECKOUT_VIP_URL=https://pay.kirvano.com/exemplo-vip

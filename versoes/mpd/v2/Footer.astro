---
import logoWorkshop from '../../../fotos/logoWorkshop.svg';
---

<footer class="w-full bg-stone-900 text-stone-400 pt-8 pb-24 lg:pb-8 px-6 md:px-12 border-t border-stone-800">
  <div class="max-w-7xl mx-auto flex flex-col items-center text-center gap-4">
    <img src={logoWorkshop.src} alt="Workshop Marca Pessoal Definitiva" class="h-14 w-auto" />
    <p class="text-sm text-stone-500 max-w-md font-sans">
      23 e 24 de Maio · Online ao vivo · Conduzido por Ton Luccas
    </p>
    <p class="text-xs text-stone-500 font-sans">
      © Ton Luccas · Vorus · Pagamento processado via Kiwify
    </p>
  </div>
</footer>

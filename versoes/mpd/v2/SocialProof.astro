---
import { Image } from 'astro:assets';
import t1 from '../../../cases/testimonial-1.png';
import t2 from '../../../cases/testimonial-2.png';
import t3 from '../../../cases/testimonial-3.png';
import t4 from '../../../cases/testimonial-4.png';

const testimonials = [
  { src: t1, alt: 'Depoimento de aluno do último workshop Marca Pessoal Definitiva' },
  { src: t2, alt: 'Depoimento de aluno do último workshop Marca Pessoal Definitiva' },
  { src: t3, alt: 'Depoimento de aluno do último workshop Marca Pessoal Definitiva' },
  { src: t4, alt: 'Depoimento de aluno do último workshop Marca Pessoal Definitiva' },
];
---

<section id="prova-social-workshop" class="ds-section w-full bg-[#E6E3D6] py-14 md:py-24 lg:py-12 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 md:mb-16 lg:mb-8">
      <h2 class="text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-stone-900 mb-6 font-serif font-medium w-fit mx-auto">
        Veja o que dizem sobre
        <span class="block italic text-stone-600 whitespace-nowrap text-4xl md:text-6xl lg:text-5xl ml-8 md:ml-16 lg:inline lg:ml-3">o último workshop:</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 items-start">
      {testimonials.map((t, i) => (
        <div class={`rounded-2xl bg-white border border-stone-200 overflow-hidden ${i % 2 === 0 ? 'transform md:rotate-[-1deg]' : 'transform md:rotate-[1deg]'} hover:rotate-0 transition-transform duration-500 shadow-lg shadow-stone-900/5`}>
          <Image
            src={t.src}
            alt={t.alt}
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 88vw, (max-width: 1024px) 44vw, 22vw"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

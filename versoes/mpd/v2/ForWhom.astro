---
const checkoutStandardUrl = import.meta.env.PUBLIC_CHECKOUT_STANDARD_URL || '#pricing';

const profiles = [
  'especialista',
  'mentor',
  'empresário',
  'prestador de serviço',
  'creator',
  'infoprodutor',
];
---

<section id="para-quem" class="ds-section w-full bg-stone-950 text-[#E6E3D6] py-14 md:py-24 px-6 md:px-12">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-[#E6E3D6] mb-12 md:mb-16 font-serif font-medium">
      O Workshop é para você
      <span class="italic">que:</span>
    </h2>

    <!-- Typewriter rotator -->
    <div class="mb-12 md:mb-16 flex flex-wrap items-baseline justify-center gap-x-3 md:gap-x-5 gap-y-1">
      <span class="text-2xl md:text-4xl font-serif italic text-stone-400">é</span>
      <span class="whitespace-nowrap"><span
          id="for-whom-rotator"
          data-profiles={JSON.stringify(profiles)}
          class="font-serif font-medium text-4xl sm:text-5xl md:text-7xl lg:text-8xl text-[#D4F268] leading-none"
        >especialista</span><span class="for-whom-cursor inline-block w-[0.1em] h-[0.95em] bg-[#D4F268] align-baseline" aria-hidden="true"></span></span>
    </div>

    <div class="max-w-2xl mx-auto space-y-4 text-base md:text-lg text-stone-300 leading-relaxed font-sans mb-10 md:mb-14 text-left">
      <p>E quer construir uma marca impossível de ignorar.</p>
      <p>Mas sabe que a sua marca pessoal ainda não traduz seu real potencial.</p>
    </div>

    <!-- Punchline — highlighter lime swipe on the key phrase -->
    <p class="my-10 md:my-14 max-w-2xl mx-auto text-[#E6E3D6] font-serif italic text-lg md:text-xl leading-snug text-center">
      E se sente com <mark class="bg-[#D4F268]/40 text-[#E6E3D6] font-medium px-1.5 py-0.5 rounded-sm box-decoration-clone">muito potencial e pouco resultado</mark>.
    </p>

    <div class="mt-12 text-center">
      <a
        href={checkoutStandardUrl}
        data-cta="forwhom-standard"
        class="inline-flex items-center justify-center px-8 py-4 bg-[#D4F268] hover:bg-[#C3E354] text-stone-900 rounded-full text-lg font-semibold transition-all transform hover:-translate-y-0.5 shadow-xl shadow-[#D4F268]/15 font-sans text-center"
      >
        Quero construir minha marca
      </a>
    </div>
  </div>
</section>

<style>
  .for-whom-cursor {
    margin-left: 0.08em;
    animation: forWhomBlink 0.9s step-end infinite;
  }
  @keyframes forWhomBlink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .for-whom-cursor {
      display: none;
    }
  }
</style>

<script>
  import { trackEvent } from '@lib/tracking';

  const rotator = document.getElementById('for-whom-rotator');
  if (rotator) {
    const profiles: string[] = JSON.parse(rotator.dataset.profiles || '[]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (profiles.length > 1 && !reduceMotion) {
      const TYPE_SPEED = 90;
      const DELETE_SPEED = 50;
      const PAUSE_TYPED = 1500;
      const PAUSE_DELETED = 300;

      let wordIndex = 0;
      let charIndex = profiles[0].length;
      let isDeleting = true;

      function tick() {
        const word = profiles[wordIndex];

        if (!isDeleting) {
          charIndex++;
          rotator!.textContent = word.slice(0, charIndex);

          if (charIndex >= word.length) {
            isDeleting = true;
            window.setTimeout(tick, PAUSE_TYPED);
            return;
          }
          window.setTimeout(tick, TYPE_SPEED);
        } else {
          charIndex--;
          rotator!.textContent = word.slice(0, charIndex);

          if (charIndex <= 0) {
            isDeleting = false;
            wordIndex = (wordIndex + 1) % profiles.length;
            window.setTimeout(tick, PAUSE_DELETED);
            return;
          }
          window.setTimeout(tick, DELETE_SPEED);
        }
      }

      window.setTimeout(tick, PAUSE_TYPED);
    }
  }

  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="forwhom-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 47,
        cta_location: 'forwhom',
        items: [{ item_id: 'workshop-mp-definitiva-standard', item_name: 'Standard', price: 47, quantity: 1 }],
      });
    });
  });
</script>

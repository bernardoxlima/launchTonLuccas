---
import { Picture } from 'astro:assets';
import tonHero from '../../../fotos/ton-hero-image.webp';
import logoWorkshop from '../../../fotos/logoWorkshop.svg';

const checkoutStandardUrl = import.meta.env.PUBLIC_CHECKOUT_STANDARD_URL || 'https://chk.eduzz.com/39ZREE8OWE?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=';

const tickerItems = [
  '77% vendidos · Lote 01',
  'Online ao vivo',
  '23 e 24 de Maio',
  '9h30 às 17h30',
  'Conduzido por TEDxSpeaker',
  'Mesmo método da consultoria de R$ 60.000',
];
---

<header id="hero" class="relative bg-stone-950 w-full overflow-hidden">
  {/* Header overlay — fora do wrapper da foto pra spanar toda a largura do <header>.
      Logo esquerda + data direita. z-30 acima de tudo. Mobile inalterado. */}
  <div class="absolute top-0 left-0 right-0 z-30 px-5 md:px-10 lg:px-12 pt-6 md:pt-8 lg:pt-10">
    <div class="flex items-start justify-between max-w-7xl mx-auto gap-4">
      <a href="/" class="block flex-shrink-0" aria-label="Workshop Marca Pessoal Definitiva">
        <img
          src={logoWorkshop.src}
          alt="Workshop Marca Pessoal Definitiva"
          width="180"
          height="80"
          class="h-12 md:h-14 lg:h-16 w-auto"
        />
      </a>

      <div class="text-right flex-shrink-0">
        <p class="text-sm md:text-base lg:text-lg font-semibold text-[#E6E3D6] leading-tight font-sans">
          23 e 24 de Maio
        </p>
        <p class="text-xs md:text-sm text-stone-300 leading-tight font-sans mt-0.5">
          9h30 às 17h30
        </p>
      </div>
    </div>
  </div>

  {/* Grid 2-col em lg+. Mobile/tablet = stacked (foto em cima, texto embaixo, padrão block). */}
  <div class="lg:grid lg:grid-cols-2 lg:min-h-[68vh]">
    {/* IMAGE COLUMN — lg:order-2 (direita) */}
    <div class="relative w-full min-h-[55vh] md:min-h-[65vh] lg:min-h-[68vh] lg:order-2">
      <div class="absolute top-12 md:top-14 lg:top-24 left-0 right-0 bottom-0 overflow-hidden">
        <Picture
          src={tonHero}
          alt="Ton Luccas — retrato conceitual representando a crise de identidade digital"
          widths={[400, 600, 800, 1200, 1600]}
          sizes="(max-width: 1023px) 100vw, 50vw"
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          class="w-full h-full object-cover object-[center_top] lg:object-[center_top]"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      {/* Fade-to-black bottom — só mobile/tablet (em lg+ texto está em coluna separada) */}
      <div class="absolute bottom-0 left-0 right-0 h-20 md:h-28 lg:hidden bg-gradient-to-t from-stone-950 via-stone-950/40 to-transparent pointer-events-none"></div>
    </div>

    {/* TEXT COLUMN — lg:order-1 (esquerda) */}
    <section class="ds-section relative z-10 px-6 md:px-10 lg:px-12 -mt-16 md:-mt-20 lg:mt-0 pb-10 md:pb-14 lg:pb-12 lg:pt-32 text-center lg:text-left lg:order-1 lg:flex lg:flex-col lg:justify-center">
      <div class="max-w-3xl mx-auto lg:max-w-xl">
        <h1 class="text-[2rem] sm:text-4xl md:text-5xl lg:text-6xl leading-[1.1] tracking-tight text-[#E6E3D6] mb-6 md:mb-8 font-serif font-medium">
          Construa sua marca pessoal forte, original e <span class="whitespace-nowrap">lucrativa <span class="italic text-stone-400">em apenas 2 dias.</span></span>
        </h1>

        <p class="text-base md:text-lg text-stone-300 leading-relaxed mb-8 md:mb-10 font-sans max-w-2xl mx-auto">
          Você vai sair com um plano claro para se posicionar, produzir conteúdo e ser percebido como uma autoridade impossível de ignorar.
        </p>

        {/* CTA primário full-width em mobile, auto em desktop */}
        <a
          href={checkoutStandardUrl}
          data-cta="hero-standard"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 md:py-5 bg-[#D4F268] hover:bg-[#C3E354] text-stone-900 rounded-full text-base md:text-lg font-semibold transition-all transform hover:-translate-y-0.5 shadow-xl shadow-[#D4F268]/20 font-sans mb-8 text-center"
        >
          Quero minha vaga no Lote 1 · R$ 47
        </a>

        {/* Barra de progresso */}
        <div class="w-full max-w-sm mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-sans">Lote 01</span>
            <span class="text-[10px] uppercase tracking-[0.2em] text-[#D4F268] font-semibold font-sans">77% vendidos</span>
          </div>
          <div class="w-full h-1 bg-stone-800 rounded-full overflow-hidden">
            <div class="h-full bg-[#D4F268] rounded-full" style="width: 77%"></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  {/* Ticker marquee — full-width abaixo do grid (mensagens rolando horizontalmente) */}
  <div class="relative border-y border-stone-800/60 bg-stone-900/40 overflow-hidden py-3">
    <div class="ticker-track flex whitespace-nowrap">
      {/* Conteúdo duplicado para loop contínuo */}
      <div class="flex items-center shrink-0">
        {tickerItems.map((item) => (
          <span class="inline-flex items-center gap-3 px-6 text-xs md:text-sm text-stone-300 font-sans uppercase tracking-[0.15em]">
            {item}
            <span class="w-1 h-1 rounded-full bg-[#D4F268]"></span>
          </span>
        ))}
      </div>
      <div class="flex items-center shrink-0" aria-hidden="true">
        {tickerItems.map((item) => (
          <span class="inline-flex items-center gap-3 px-6 text-xs md:text-sm text-stone-300 font-sans uppercase tracking-[0.15em]">
            {item}
            <span class="w-1 h-1 rounded-full bg-[#D4F268]"></span>
          </span>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .ticker-track {
    animation: marquee-scroll 35s linear infinite;
    width: max-content;
  }
  .ticker-track:hover {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
</style>

<script>
  import { trackEvent } from '@lib/tracking';

  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="hero-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 47,
        cta_location: 'hero',
        items: [{ item_id: 'workshop-mp-definitiva-standard', item_name: 'Standard', price: 47, quantity: 1 }],
      });
    });
  });
</script>

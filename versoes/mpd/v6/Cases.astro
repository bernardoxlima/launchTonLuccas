---
import { Image } from 'astro:assets';
import cacaPhoto from '../../../cases/Caca Montans/caca.jpg';
import yangPhoto from '../../../cases/Yang Mendes/yang.jpg';
import nathaliaPhoto from '../../../cases/Nathalia/nathalia.jpg';

const cases = [
  {
    name: 'Caca Montans',
    photo: cacaPhoto,
    alt: 'Caca Montans — case de marca pessoal mentorada por Ton Luccas',
    niche: 'Mentor de relacionamento · Público feminino',
    headline: '+100 mil seguidores em 3 meses. High-ticket destravado.',
    description: 'Audiência ele tinha. O que faltava: lead virando venda e ticket médio crescendo. Quando refez marca, território e percepção, os dois problemas viraram passado.',
  },
  {
    name: 'Yang Mendes',
    photo: yangPhoto,
    alt: 'Yang Mendes — case de marca pessoal mentorada por Ton Luccas',
    niche: 'Oratória para empreendedores · 27 anos no mercado',
    headline: '15 mil → 90 mil seguidores em 3 meses. Zero concorrente novo.',
    description: '27 anos treinando empreendedores. Palavras dele: "todo dia nasce um professor de oratória no digital e vira meu concorrente". O problema nunca foi conhecimento. Era território. Em 3 meses reposicionado, virou a categoria que ninguém mais confunde com mais um.',
  },
  {
    name: 'Nathalia',
    photo: nathaliaPhoto,
    alt: 'Nathalia — case de marca pessoal mentorada por Ton Luccas',
    niche: 'Advogada de vistos · Imigração',
    headline: '4 anos parada em 1.600 seguidores. 5 meses no método: 146 mil.',
    description: 'Quatro anos. 1.600 seguidores. A maioria teria desistido. Nathalia reposicionou marca, território e mensagem, e fez em 5 meses o que 4 anos de tentativa não fizeram: virou a advogada de visto que o algoritmo entrega primeiro.',
  },
];
---

<section id="cases" class="ds-section w-full bg-stone-950 text-[#E6E3D6] py-14 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 md:mb-16">
      <h2 class="text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-[#E6E3D6] mb-6 font-serif font-medium w-fit mx-auto">
        Quem aplicou o método,
        <span class="block italic text-stone-400 ml-8 md:ml-16 lg:inline lg:ml-3">já está colhendo resultados</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {cases.map((c) => (
        <article class="group bg-stone-900 rounded-3xl overflow-hidden border border-stone-700 hover:border-[#D4F268]/40 transition-colors duration-300 flex flex-col">
          <div class="relative aspect-square overflow-hidden bg-stone-800">
            <Image
              src={c.photo}
              alt={c.alt}
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 88vw, 400px"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-950/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 text-[#E6E3D6]">
              <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-1 font-sans">
                Case
              </p>
              <p class="text-2xl font-serif font-light leading-tight">{c.name}</p>
            </div>
          </div>

          <div class="p-6 md:p-7 flex-1 flex flex-col">
            <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-stone-400 mb-3 font-sans">
              {c.niche}
            </p>
            <p class="text-base md:text-lg font-serif font-medium text-[#D4F268] leading-snug mb-4">
              {c.headline}
            </p>
            <p class="text-sm text-stone-300 leading-relaxed font-sans">
              {c.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

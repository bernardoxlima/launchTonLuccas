---
const checkoutStandardUrl = import.meta.env.PUBLIC_CHECKOUT_STANDARD_URL || 'https://pay.kirvano.com/cd45d82c-9fe5-44f3-8b41-8fce3b50437b?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=';

const day1Items = [
  {
    n: '01',
    title: 'Diagnóstico da sua marca atual',
    body: 'Você vai identificar onde sua comunicação está genérica, confusa ou desalinhada com a autoridade que você realmente tem.',
  },
  {
    n: '02',
    title: 'Clareza do seu território de marca',
    body: 'Você vai começar a definir qual espaço mental sua marca deve ocupar para deixar de ser mais uma opção no mercado.',
  },
  {
    n: '03',
    title: 'Sua diferença impossível de copiar',
    body: 'Você vai mapear quais partes da sua história, repertório, visão de mundo e personalidade podem virar diferencial estratégico.',
  },
  {
    n: '04',
    title: 'O inimigo que sua marca combate',
    body: 'Toda marca forte se posiciona contra alguma coisa. Você vai entender qual tensão do mercado sua marca precisa enfrentar para gerar identificação e desejo.',
  },
  {
    n: '05',
    title: 'A base da sua mensagem central',
    body: 'Você vai começar a transformar sua essência em uma ideia clara, memorável e comunicável.',
  },
];

const day2Items = [
  {
    n: '01',
    title: 'Sua narrativa de autoridade',
    body: 'Como organizar sua trajetória, experiências, conquistas, visão de mundo e repertório em uma história que sustenta posicionamento.',
  },
  {
    n: '02',
    title: 'Sua comunicação',
    body: 'Como encontrar o tom, a linguagem e os ângulos que fazem seu conteúdo parecer seu, e não uma adaptação do que todo mundo está fazendo.',
  },
  {
    n: '03',
    title: 'Seu formato de conteúdo autoral',
    body: 'Como produzir conteúdo a partir da sua personalidade, energia, repertório e território, sem depender de trend, dancinha ou fórmula importada.',
  },
  {
    n: '04',
    title: 'Sua imagem estratégica',
    body: 'Como alinhar estética, presença, cenário, roupas, símbolos e percepção visual com o lugar que você quer ocupar no mercado.',
  },
  {
    n: '05',
    title: 'Seu mapa de aplicação',
    body: 'O que fazer depois do workshop para transformar o território construído em perfil, conteúdo, oferta, vendas e autoridade consistente.',
  },
];

---

<section id="cronograma" class="ds-section w-full bg-stone-950 text-[#E6E3D6] py-14 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="max-w-3xl lg:max-w-5xl mx-auto text-center mb-10 md:mb-16">
      <h2 class="text-3xl md:text-5xl lg:text-4xl leading-[1.1] tracking-tight text-[#E6E3D6] mb-8 font-serif font-medium">
        Dois dias para deixar de improvisar sua marca pessoal,<br class="lg:hidden" />
        <span class="italic text-stone-400">e construir um posicionamento <span class="text-[#FBFCD4]">impossível de copiar.</span></span>
      </h2>

      <div class="space-y-5 text-lg text-stone-300 leading-relaxed font-sans text-left">
        <p>
          Esse não é um workshop para você assistir, <span class="text-[#FBFCD4]">anotar frases bonitas</span> e voltar para o mesmo lugar. <mark class="bg-[#FBFCD4] text-stone-900 font-semibold px-1 py-0.5 rounded-sm box-decoration-clone">É um processo de construção.</mark>
        </p>
        <p>
          Você vai construir uma estrutura clara sobre <span class="text-[#FBFCD4]">quem você é no digital</span>, o que sua marca representa, como sua autoridade deve ser percebida e descobrir qual caminho seguir para transformar isso em <mark class="bg-[#FBFCD4] text-stone-900 font-semibold px-1 py-0.5 rounded-sm box-decoration-clone">conteúdo, desejo e venda</mark>.
        </p>
      </div>
    </div>

    {/* Dia 1 + Dia 2: 2-col grid em lg+ (cards lado a lado), stacked em mobile/md */}
    <div class="lg:grid lg:grid-cols-2 lg:gap-6 lg:items-start mb-12 md:mb-16">
    {/* Dia 1 */}
    <article class="bg-transparent rounded-3xl p-8 md:p-12 lg:p-8 text-[#E6E3D6] border border-[#D4F268]/40 hover:border-[#D4F268]/70 transition-colors mb-8 lg:mb-0 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-[#D4F268]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
      <div class="mb-6 pb-6 border-b border-[#D4F268]/20 relative z-10">
        <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-3 font-sans">
          Dia 1 · 23 de Maio
        </p>
        <span class="inline-block px-3 py-1 mb-5 rounded-full border border-[#D4F268]/50 text-[11px] font-bold text-[#D4F268] tracking-[0.15em] uppercase font-sans">
          A crise de identidade digital
        </span>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-serif font-medium text-[#E6E3D6] leading-tight max-w-3xl">
          Por que especialistas bons continuam invisíveis <span class="italic text-stone-400">e como descobrir o território que só você pode ocupar?</span>
        </h3>
      </div>

      <p class="text-base text-stone-300 leading-relaxed font-sans mb-8 max-w-3xl relative z-10">
        No primeiro dia, você vai entender por que tanta gente competente não consegue crescer, vender ou ser lembrada no digital. Você vai enxergar o que está por trás da confusão da sua marca pessoal e começar a separar o que é essência do que é ruído.
      </p>

      <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-6 font-sans relative z-10">
        O que você vai construir no Dia 1
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-6 mb-8 relative z-10">
        {day1Items.map((item) => (
          <div class="flex gap-4">
            <span class="text-3xl font-serif font-light text-[#D4F268]/40 shrink-0">{item.n}</span>
            <div>
              <h4 class="text-lg font-medium text-[#E6E3D6] mb-2 font-sans">{item.title}</h4>
              <p class="text-sm text-stone-300 leading-relaxed font-sans">{item.body}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-base md:text-lg text-stone-300 leading-relaxed font-sans pt-6 border-t border-[#D4F268]/20 relative z-10">
        Ao final do primeiro dia, você vai entender por que sua marca ainda não encaixava <span class="text-[#E6E3D6] font-medium">— e qual é a base que precisa ser construída para ela finalmente fazer sentido.</span>
      </p>
    </article>

    {/* Dia 2 — premium card */}
    <article class="bg-transparent rounded-3xl p-8 md:p-12 lg:p-8 text-[#E6E3D6] border border-[#D4F268]/40 hover:border-[#D4F268]/70 transition-colors mb-0 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-[#D4F268]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
      <div class="mb-6 pb-6 border-b border-[#D4F268]/20 relative z-10">
        <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-3 font-sans">
          Dia 2 · 24 de Maio
        </p>
        <span class="inline-block px-3 py-1 mb-5 rounded-full border border-[#D4F268]/50 text-[11px] font-bold text-[#D4F268] tracking-[0.15em] uppercase font-sans">
          A construção da marca pessoal
        </span>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-serif font-medium leading-tight max-w-3xl">
          Como transformar sua essência em mensagem, imagem, conteúdo <span class="italic text-stone-400">e autoridade percebida?</span>
        </h3>
      </div>

      <p class="text-base text-stone-300 leading-relaxed font-sans mb-8 max-w-3xl relative z-10">
        No segundo dia, você vai sair da consciência e entrar na construção.
      </p>

      <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-6 font-sans relative z-10">
        O que você vai construir no Dia 2
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-6 relative z-10">
        {day2Items.map((item) => (
          <div class="flex gap-4">
            <span class="text-3xl font-serif font-light text-[#D4F268]/40 shrink-0">{item.n}</span>
            <div>
              <h4 class="text-lg font-medium text-[#E6E3D6] mb-2 font-sans">{item.title}</h4>
              <p class="text-sm text-stone-300 leading-relaxed font-sans">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </article>
    </div>

    {/* Promessa — 3 linhas: heading, body, highlighted */}
    <div class="py-8 md:py-12 mb-10">
      <p class="text-base md:text-lg font-bold tracking-[0.25em] uppercase text-[#D4F268] font-sans text-center mb-10 md:mb-12">
        A promessa desses<br class="md:hidden" /> 2 dias é simples
      </p>

      <p class="text-center max-w-3xl mx-auto text-base md:text-lg text-stone-300 leading-relaxed font-sans mb-10 md:mb-12">
        Você vai parar de tentar construir sua marca com pedaços dos outros <span class="italic text-stone-400">e vai construir uma marca pessoal</span>
      </p>

      <p class="text-center font-serif font-medium tracking-tight leading-[1.05] mb-14 md:mb-16 text-4xl sm:text-5xl md:text-6xl lg:text-7xl">
        <span class="text-[#E6E3D6]">Original,</span>
        <span class="italic text-stone-300"> forte </span>
        <span class="text-[#D4F268]">&amp; lucrativa.</span>
      </p>

      <a
        href={checkoutStandardUrl}
        data-cta="schedule-standard"
        class="block w-full py-5 px-6 rounded-full bg-[#D4F268] hover:bg-[#C3E354] text-stone-900 text-lg md:text-xl font-semibold text-center transition-all transform hover:-translate-y-0.5 shadow-xl shadow-[#D4F268]/15 font-sans"
      >
        Quero minha vaga no workshop
      </a>
    </div>

    {/* Cronograma operacional */}
    <div class="bg-gradient-to-br from-[#D4F268]/8 via-transparent to-[#D4F268]/15 rounded-3xl p-8 md:p-10 relative overflow-hidden border border-[#D4F268]/30">
      <div class="absolute top-0 right-0 w-64 h-64 bg-[#D4F268]/8 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#D4F268]/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>

      <p class="text-[11px] font-bold tracking-[0.2em] uppercase text-[#D4F268] mb-4 font-sans relative z-10">
        Cronograma
      </p>

      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-stone-900/60 border border-[#D4F268]/20 mb-6 relative z-10">
        <span class="w-1.5 h-1.5 rounded-full bg-[#D4F268]"></span>
        <span class="text-sm text-[#E6E3D6] font-sans">23 e 24 de Maio · Online no Zoom</span>
      </div>

      <div class="flex flex-col lg:flex-row lg:gap-4 gap-2 relative z-10">
        <div class="bg-stone-900/50 rounded-lg px-4 py-3 border-l-4 border-[#D4F268] lg:flex-1">
          <p class="text-base font-medium text-[#E6E3D6] font-sans leading-snug">Início</p>
          <p class="text-sm text-stone-400 font-sans">9h30</p>
        </div>
        <div class="bg-stone-900/50 rounded-lg px-4 py-3 border-l-4 border-[#D4F268] lg:flex-1">
          <p class="text-base font-medium text-[#E6E3D6] font-sans leading-snug">Almoço</p>
          <p class="text-sm text-stone-400 font-sans">12h</p>
        </div>
        <div class="bg-stone-900/50 rounded-lg px-4 py-3 border-l-4 border-[#D4F268] lg:flex-1">
          <p class="text-base font-medium text-[#E6E3D6] font-sans leading-snug">Retorno</p>
          <p class="text-sm text-stone-400 font-sans">14h</p>
        </div>
        <div class="bg-stone-900/50 rounded-lg px-4 py-3 border-l-4 border-[#D4F268] lg:flex-1">
          <p class="text-base font-medium text-[#E6E3D6] font-sans leading-snug">Fechamento</p>
          <p class="text-sm text-stone-400 font-sans">17h30</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { trackEvent } from '@lib/tracking';
  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="schedule-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 47,
        cta_location: 'schedule',
        items: [{ item_id: 'workshop-mp-definitiva-standard', item_name: 'Standard', price: 47, quantity: 1 }],
      });
    });
  });
</script>

---
const checkoutStandardUrl = import.meta.env.PUBLIC_CHECKOUT_STANDARD_URL || 'https://pay.kirvano.com/cd45d82c-9fe5-44f3-8b41-8fce3b50437b?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=';
---

{/* Sticky CTA bar — só aparece em mobile, depois que usuário rola além do hero */}
<div id="sticky-cta" class="sticky-cta lg:!hidden">
  <div class="sticky-cta-inner">
    <div class="flex items-center gap-3 max-w-md mx-auto">
      <div class="flex-shrink-0">
        <p class="text-[10px] font-bold tracking-[0.15em] uppercase text-stone-400 leading-none mb-1 font-sans">
          Lote 01
        </p>
        <p class="text-lg font-serif font-light text-[#E6E3D6] leading-none">
          R$ <span class="text-2xl">47</span>
          <span class="text-xs text-stone-500 ml-1">12x R$ 4,70</span>
        </p>
      </div>

      <a
        href={checkoutStandardUrl}
        data-cta="sticky-standard"
        class="flex-1 min-h-[48px] inline-flex items-center justify-center px-4 py-3 bg-[#D4F268] hover:bg-[#C3E354] active:scale-95 text-stone-900 rounded-full text-sm font-semibold transition-all shadow-lg shadow-[#D4F268]/20 font-sans text-center"
      >
        Garantir vaga
      </a>
    </div>
  </div>
</div>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transform: translateY(100%);
    transition: transform 0.3s ease-out;
    pointer-events: none;
  }
  .sticky-cta[data-visible="true"] {
    transform: translateY(0);
    pointer-events: auto;
  }
  .sticky-cta-inner {
    background-color: rgba(28, 25, 23, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(120, 113, 108, 0.4);
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
  }
</style>

<script>
  import { trackEvent } from '@lib/tracking';

  const stickyEl = document.getElementById('sticky-cta');
  const heroEl = document.getElementById('hero');
  const pricingEl = document.getElementById('pricing');

  if (stickyEl && heroEl && 'IntersectionObserver' in window) {
    let heroOut = false;
    let pricingIn = false;

    const update = () => {
      const shouldShow = heroOut && !pricingIn;
      stickyEl.dataset.visible = shouldShow ? 'true' : 'false';
    };

    // Trigger ao usar 1px sentinel no fim do hero
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;bottom:80px;left:0;width:1px;height:1px;pointer-events:none';
    heroEl.style.position = heroEl.style.position || 'relative';
    heroEl.appendChild(sentinel);

    const heroObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          heroOut = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          update();
        });
      },
      { threshold: 0, rootMargin: '0px' }
    );
    heroObserver.observe(sentinel);

    if (pricingEl) {
      const pricingObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            pricingIn = entry.isIntersecting;
            update();
          });
        },
        { threshold: 0.15 }
      );
      pricingObserver.observe(pricingEl);
    }
  }

  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="sticky-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 47,
        cta_location: 'sticky',
        items: [{ item_id: 'workshop-mp-definitiva-standard', item_name: 'Standard', price: 47, quantity: 1 }],
      });
    });
  });
</script>

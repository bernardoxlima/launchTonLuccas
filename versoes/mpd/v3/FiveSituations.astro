---
import { Icon } from 'astro-icon/components';

const situations = [
  {
    n: '01',
    title: 'Você sabe muito, mas ainda parece comum no digital',
    body: 'Por dentro, você tem profundidade. Por fora, sua comunicação ainda parece genérica. E isso cria uma injustiça: pessoas menos preparadas que você ocupam mais espaço simplesmente porque são melhores posicionadas.',
    icon: 'solar:user-id-linear',
  },
  {
    n: '02',
    title: 'Você produz conteúdo, mas sente que não está construindo marca',
    body: 'Você posta, entrega valor, tenta manter frequência… Mas no fim parece que cada conteúdo morre nele mesmo. Não constrói uma percepção sólida sobre quem você é.',
    icon: 'solar:posts-carousel-vertical-linear',
  },
  {
    n: '03',
    title: 'Você sente que sua imagem não acompanha sua autoridade',
    body: 'Você sabe que é bom. Mas seu perfil, sua estética, sua comunicação, seus conteúdos e sua presença ainda não transmitem o nível de autoridade que você realmente tem.',
    icon: 'solar:gallery-linear',
  },
  {
    n: '04',
    title: 'Você cansou de tentar se encaixar no formato dos outros',
    body: 'Você não quer mais abrir o Instagram, olhar para sua própria marca e sentir que está performando uma versão estranha de si mesmo. Você quer encontrar uma forma de crescer sem perder sua essência.',
    icon: 'solar:hashtag-circle-linear',
  },
];
---

<section id="situacoes" class="ds-section w-full bg-[#E6E3D6] py-14 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 md:mb-16">
      <h2 class="text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-stone-900 mb-8 font-serif font-medium w-fit mx-auto">
        Eu sei que você vive
        <span class="block italic text-stone-600 whitespace-nowrap text-4xl md:text-6xl lg:text-5xl ml-8 md:ml-16 lg:inline lg:ml-3">uma dessas situações:</span>
      </h2>
    </div>

    <div class="space-y-4 md:grid md:grid-cols-2 md:gap-6 md:space-y-0">
      {situations.map((s, i) => {
        const themes = [
          {
            card: 'bg-white border border-stone-200',
            iconBox: 'bg-[#E6E3D6] text-stone-700',
            number: 'text-stone-500',
            title: 'text-stone-900',
            body: 'text-stone-700',
          },
          {
            card: 'bg-[#D4F268]/20 border border-[#D4F268]/50',
            iconBox: 'bg-white text-stone-900 border border-stone-900/10',
            number: 'text-stone-900',
            title: 'text-stone-900',
            body: 'text-stone-700',
          },
          {
            card: 'bg-[#5A5C4F] border border-[#5A5C4F]',
            iconBox: 'bg-[#D4F268] text-stone-900',
            number: 'text-[#D4F268]',
            title: 'text-white',
            body: 'text-white',
          },
          {
            card: 'bg-[#FBFCD4] border border-stone-900/10',
            iconBox: 'bg-stone-900 text-[#FBFCD4]',
            number: 'text-stone-900/60',
            title: 'text-stone-900',
            body: 'text-stone-700',
          },
        ];
        const t = themes[i];
        return (
          <article class={`${t.card} rounded-3xl p-6 md:p-10`}>
            <div class="flex items-center justify-between mb-6">
              <div class="w-14 h-14 flex items-center justify-center shrink-0">
                <span class={`text-5xl md:text-6xl font-serif font-medium leading-none ${t.number}`}>{s.n}</span>
              </div>
              <div class={`w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 ${t.iconBox}`}>
                <Icon name={s.icon} width={28} height={28} />
              </div>
            </div>

            <h3 class={`text-xl md:text-2xl lg:text-3xl font-serif font-bold mb-4 leading-tight ${t.title}`}>{s.title}</h3>
            <p class={`text-base md:text-lg leading-relaxed font-sans ${t.body}`}>{s.body}</p>
          </article>
        );
      })}
    </div>

    <div class="mt-16 text-center">
      <a
        href="#pricing-standard"
        data-cta="situations-standard"
        class="inline-flex items-center justify-center px-7 py-3.5 bg-stone-900 hover:bg-stone-800 text-[#D4F268] rounded-full text-base md:text-lg font-medium transition-all transform hover:-translate-y-0.5 shadow-xl shadow-stone-900/20 font-sans text-center"
      >
        Quero construir minha Marca Pessoal
      </a>
    </div>
  </div>
</section>

<script>
  import { trackEvent } from '@lib/tracking';
  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="situations-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('select_promotion', {
        promotion_name: 'pricing-section',
        cta_location: 'situations',
      });
    });
  });
</script>

---
import { Icon } from 'astro-icon/components';
const checkoutStandardUrl = import.meta.env.PUBLIC_CHECKOUT_STANDARD_URL || 'https://pay.kirvano.com/cd45d82c-9fe5-44f3-8b41-8fce3b50437b?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=';
const checkoutVipUrl = import.meta.env.PUBLIC_CHECKOUT_VIP_URL || 'https://pay.kirvano.com/5971d946-f3f1-482a-89da-5e01cb14cfee?utm_source=organic&utm_campaign=&utm_medium=&utm_content=&utm_term=';

const standardFeatures = [
  { title: 'Workshop ao vivo com Ton Luccas', body: 'Dias 23 e 24 de maio' },
  { title: 'Materiais das aulas', body: 'Arquivos e materiais usados durante o workshop' },
  { title: 'Tarefas práticas do ao vivo', body: 'Exercícios liberados durante a experiência ao vivo' },
  { title: 'Construção da sua marca pessoal em tempo real', body: '' },
];

const vipExtras = [
  { title: 'Q&A exclusivo com Ton Luccas', body: 'Um encontro fechado de perguntas e respostas após o workshop' },
  { title: 'Workshop em formato de aulas', body: 'A gravação completa do evento organizada em aulas para você assistir no seu ritmo' },
  { title: 'Acesso por 12 meses', body: 'Você poderá rever as aulas, revisar os exercícios e aplicar com calma durante 1 ano' },
  { title: 'Materiais complementares VIP', body: 'Conteúdos extras para aprofundar a construção da sua marca pessoal' },
];
---

<section id="pricing" class="ds-section w-full bg-stone-950 text-[#E6E3D6] py-14 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto text-center mb-10 md:mb-16">
      <h2 class="text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-[#E6E3D6] mb-6 font-serif font-medium">
        Seu investimento:
      </h2>

      <p class="text-lg text-stone-300 leading-relaxed font-sans">
        Duas formas de entrar no workshop. Ambas dão acesso aos 2 dias ao vivo. O VIP estende a experiência além do evento.
      </p>
    </div>

    {/* Pricing 2-up */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-12">
      {/* STANDARD */}
      <article class="bg-transparent rounded-3xl p-8 md:p-10 border border-[#D4F268]/30 hover:border-[#D4F268]/60 flex flex-col group transition-colors duration-300">
        <div class="flex justify-end mb-6">
          <span class="inline-block px-3 py-1 rounded-full bg-stone-800 text-[11px] font-bold text-stone-300 tracking-[0.15em] uppercase font-sans border border-stone-700">Lote 01</span>
        </div>

        <h3 class="text-3xl md:text-4xl font-serif font-medium text-[#E1306C] mb-2 leading-tight tracking-wider uppercase">Ingresso Standard</h3>
        <p class="text-base text-stone-300 mb-8 leading-relaxed font-sans">
          Para quem quer participar ao vivo dos 2 dias de construção da Marca Pessoal Definitiva.
        </p>

        <div class="flex items-end gap-3 mb-4">
          <span class="flex items-baseline gap-1">
            <span class="text-2xl text-stone-400 font-sans">R$</span>
            <span class="text-6xl md:text-7xl font-serif font-light text-[#E6E3D6] leading-none">47</span>
          </span>
          <span class="flex flex-col leading-tight pb-3 font-sans">
            <span class="text-base text-stone-300">à vista</span>
            <span class="text-sm text-stone-400 whitespace-nowrap">ou 12x de R$ 4,70</span>
          </span>
        </div>

        <div class="w-24 h-px bg-stone-700 mb-4"></div>

        <p class="text-xs text-stone-500 font-sans mb-2">Lote 01 · 42% vendidos</p>

        {/* Barra de progresso */}
        <div class="w-full h-1.5 bg-stone-800 rounded-full overflow-hidden mb-8">
          <div class="h-full bg-[#D4F268] rounded-full" style="width: 42%"></div>
        </div>

        <ul class="space-y-4 mb-10 flex-1">
          {standardFeatures.map((f) => (
            <li class="flex items-start gap-3">
              <Icon class="text-[#D4F268] mt-1 shrink-0" name="solar:check-circle-bold" width={20} height={20} />
              <div>
                <p class="text-base text-[#E6E3D6] leading-snug font-sans font-medium">{f.title}</p>
                {f.body && <p class="text-sm text-stone-400 leading-snug font-sans mt-0.5">{f.body}</p>}
              </div>
            </li>
          ))}
        </ul>

        <a
          href={checkoutStandardUrl}
          data-cta="pricing-standard"
          class="w-full py-4 px-6 rounded-full bg-[#E6E3D6] hover:bg-white text-stone-900 font-semibold text-base transition-all transform hover:-translate-y-0.5 inline-flex items-center justify-center font-sans text-center"
        >
          Garantir Ingresso Standard
        </a>
      </article>

      {/* VIP */}
      <article data-vip-frame class="bg-gradient-to-br from-[#D4F268]/20 via-transparent to-[#D4F268]/35 rounded-3xl p-8 md:p-10 flex flex-col relative overflow-hidden lg:-translate-y-4">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#D4F268]/15 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-72 h-72 bg-[#D4F268]/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>

        <div class="flex justify-end mb-6 relative z-10">
          <span class="inline-block px-3 py-1 rounded-full bg-[#D4F268] text-[11px] font-bold text-stone-900 tracking-[0.15em] uppercase font-sans shadow-lg shadow-[#D4F268]/20">Mais Escolhido</span>
        </div>

        <h3 class="text-3xl md:text-4xl font-serif font-medium text-[#D4F268] mb-2 leading-tight relative z-10 tracking-wider uppercase">Ingresso VIP</h3>
        <p class="text-base text-stone-300 mb-8 leading-relaxed font-sans relative z-10">
          Para quem quer a experiência completa, acesso às aulas por 12 meses e um momento exclusivo com Ton Luccas.
        </p>

        <div class="flex items-end gap-3 mb-4 relative z-10">
          <span class="flex items-baseline gap-1">
            <span class="text-2xl text-stone-300 font-sans">R$</span>
            <span class="text-6xl md:text-7xl font-serif font-light text-[#E6E3D6] leading-none">297</span>
          </span>
          <span class="flex flex-col leading-tight pb-3 font-sans">
            <span class="text-base text-stone-300">à vista</span>
            <span class="text-sm text-stone-400 whitespace-nowrap">ou 12x de R$ 29,70</span>
          </span>
        </div>

        <div class="w-24 h-px bg-[#D4F268]/40 mb-4 relative z-10"></div>

        <p class="text-sm text-stone-300 font-sans mb-6 relative z-10">
          Tudo do Ingresso Standard, <span class="text-[#D4F268] font-medium">mais:</span>
        </p>

        <ul class="space-y-4 mb-10 flex-1 relative z-10">
          {vipExtras.map((f) => (
            <li class="flex items-start gap-3">
              <Icon class="text-[#D4F268] mt-1 shrink-0" name="solar:check-circle-bold" width={20} height={20} />
              <div>
                <p class="text-base text-[#E6E3D6] leading-snug font-sans font-medium">{f.title}</p>
                {f.body && <p class="text-sm text-stone-400 leading-snug font-sans mt-0.5">{f.body}</p>}
              </div>
            </li>
          ))}
        </ul>

        <a
          href={checkoutVipUrl}
          data-cta="pricing-vip"
          class="w-full py-4 px-6 rounded-full bg-[#D4F268] hover:bg-[#C3E354] text-stone-900 font-semibold text-base transition-all transform hover:-translate-y-0.5 inline-flex items-center justify-center font-sans relative z-10 shadow-lg shadow-[#D4F268]/30 text-center"
        >
          Quero o Ingresso VIP
        </a>
      </article>
    </div>

    {/* Disclaimer abaixo */}
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm text-stone-400 font-sans">
        Pagamento processado via Kiwify. Acesso enviado por email logo após a confirmação.
      </p>
    </div>
  </div>
</section>

<script>
  import { trackEvent, trackViewPricing } from '@lib/tracking';

  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="pricing-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 47,
        cta_location: 'pricing',
        items: [{ item_id: 'workshop-mp-definitiva-standard', item_name: 'Standard', price: 47, quantity: 1 }],
      });
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="pricing-vip"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('begin_checkout', {
        currency: 'BRL',
        value: 297,
        cta_location: 'pricing',
        items: [{ item_id: 'workshop-mp-definitiva-vip', item_name: 'VIP', price: 297, quantity: 1 }],
      });
    });
  });

  // Disparar view_item_list quando o bloco entrar no viewport
  const pricingSection = document.getElementById('pricing');
  if (pricingSection && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            trackViewPricing();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(pricingSection);
  }
</script>

<style is:global>
  @property --vip-frame-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  [data-vip-frame] {
    isolation: isolate;
    box-shadow:
      0 25px 50px -12px rgba(212, 242, 104, 0.05),
      0 12px 32px -12px rgba(212, 242, 104, 0.55),
      0 0 24px rgba(212, 242, 104, 0.28);
  }

  [data-vip-frame]::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: conic-gradient(
      from var(--vip-frame-angle),
      rgba(212, 242, 104, 0.35) 0deg,
      rgba(212, 242, 104, 0.35) 220deg,
      rgba(212, 242, 104, 0.4) 280deg,
      rgba(212, 242, 104, 0.6) 330deg,
      rgba(212, 242, 104, 0.75) 360deg
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    animation: vip-frame-spin 6s linear infinite;
    z-index: 1;
  }

  @keyframes vip-frame-spin {
    to { --vip-frame-angle: 360deg; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-vip-frame]::after { animation: none; }
  }
</style>

---
---

<section id="urgencia" class="ds-section w-full bg-[#E6E3D6] py-14 md:py-24 px-6 md:px-12 overflow-x-hidden">
  <div class="max-w-3xl lg:max-w-5xl mx-auto">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="font-serif italic text-stone-800 leading-[1.15] tracking-tight text-3xl sm:text-4xl md:text-5xl font-medium text-balance">
        Quanto mais você demora para resolver sua marca pessoal, mais caro fica continuar
      </h2>

      <div class="mt-3 md:mt-5">
        <span class="block font-headline uppercase text-[2.5rem] sm:text-5xl md:text-7xl lg:text-8xl text-stone-900 leading-[0.95] tracking-[0.15em]">
          Invisível
        </span>
      </div>

      <div class="w-16 h-px bg-[#9EA08F] mx-auto mt-8 md:mt-10"></div>
    </div>

    <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start">
      <div class="space-y-4 md:space-y-5 text-base md:text-lg text-stone-700 leading-relaxed font-sans">
        <p class="text-center lg:text-left">
          Enquanto sua marca está confusa, <mark class="bg-[#FBFCD4] text-stone-900 font-semibold px-1 py-0.5 rounded-sm box-decoration-clone">o mercado não espera</mark>. Outras pessoas ocupam espaço.
        </p>

        <p>
          <mark class="bg-[#EBC8D6] text-stone-900 font-semibold px-1 py-0.5 rounded-sm box-decoration-clone">Outros especialistas, às vezes menos preparados que você, crescem mais rápido porque se comunicam com mais clareza.</mark>
        </p>
      </div>

      <div class="space-y-4 md:space-y-5 text-base md:text-lg text-stone-700 leading-relaxed font-sans">
        <!-- MANIFESTO TICKET — sage green, rotacionado -->
        <div class="relative my-10 md:my-14 lg:my-0 lg:mb-8 flex justify-center">
          <div class="w-full max-w-md bg-[#9EA08F] shadow-2xl rounded-t-lg overflow-hidden transform -rotate-2 hover:rotate-0 transition-transform duration-500">
            <!-- Body -->
            <div class="px-6 py-7">
              <p class="text-white font-serif text-xl md:text-2xl leading-snug">
                Nem sempre vence quem <strong class="font-bold">sabe mais</strong>.
              </p>
              <p class="text-white font-serif text-xl md:text-2xl leading-snug italic mt-3">
                Vence quem é mais fácil de reconhecer, lembrar e desejar.
              </p>
            </div>
            <!-- Serrated bottom -->
            <div class="h-3 w-full bg-[#E6E3D6]" style="mask-image: radial-gradient(circle at 10px 0, transparent 0, transparent 5px, black 5px); mask-size: 20px 10px; mask-repeat: repeat-x; -webkit-mask-image: radial-gradient(circle at 10px 0, transparent 0, transparent 5px, black 5px); -webkit-mask-size: 20px 10px; -webkit-mask-repeat: repeat-x;"></div>
          </div>
        </div>

        <p>
          Você pode continuar tentando resolver isso sozinho ou <mark class="bg-[#FBFCD4] text-stone-900 font-semibold px-1 py-0.5 rounded-sm box-decoration-clone">pode parar por 2 dias e construir a base</mark> que deveria ter vindo antes de todo o resto.
        </p>
      </div>
    </div>

    <!-- CTA — lime yellow -->
    <div class="mt-8 md:mt-10 text-center">
      <a
        href="#pricing-cta-standard"
        data-cta="urgency-standard"
        class="inline-flex items-center justify-center px-7 py-3.5 bg-[#D4F268] hover:bg-[#C3E354] text-stone-900 rounded-full text-base md:text-lg font-medium transition-all transform hover:-translate-y-0.5 shadow-xl shadow-[#D4F268]/30 font-sans text-center"
      >
        Quero participar do Workshop
      </a>
    </div>
  </div>
</section>

<style>
  .font-headline {
    font-family: 'Fraunces', serif;
    font-weight: 700;
  }
</style>

<script>
  import { trackEvent } from '@lib/tracking';
  document.querySelectorAll<HTMLAnchorElement>('a[data-cta="urgency-standard"]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('select_promotion', {
        promotion_name: 'pricing-section',
        cta_location: 'urgency',
      });
    });
  });
</script>
